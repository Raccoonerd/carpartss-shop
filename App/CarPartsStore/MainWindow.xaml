<Window x:Class="CarPartsStore.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CarPartsStore.ViewModels"
        Title="Sklep z częściami samochodowymi" Height="600" Width="1200">
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#2C3E50">
            <StackPanel Margin="0,20,0,0">
                <TextBlock Text="Menu"
                           Foreground="White"
                           FontSize="18" FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,30"/>

                <Button Content="Części"
                        Command="{Binding PokazCzesciCommand}"
                        Height="45" Margin="10,0,10,8"
                        Background="#34495E" Foreground="White"
                        BorderThickness="0" FontSize="14"/>

                <Button Content="Klienci"
                        Command="{Binding PokazKlientowCommand}"
                        Height="45" Margin="10,0,10,8"
                        Background="#34495E" Foreground="White"
                        BorderThickness="0" FontSize="14"/>

                <Button Content="Sprzedaż"
                        Command="{Binding PokazSprzedazCommand}"
                        Height="45" Margin="10,0,10,8"
                        Background="#34495E" Foreground="White"
                        BorderThickness="0" FontSize="14"/>
            </StackPanel>
        </Border>

        <ContentControl Grid.Column="1"
                        Content="{Binding AktualnyWidok}"
                        Margin="10"/>
    </Grid>
    
</Window>
