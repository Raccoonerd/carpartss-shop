<Window x:Class="CarPartsStore.Views.CzesciView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:vm="clr-namespace:CarPartsStore.ViewModels"
      Title="Części samochodowe"
      Height="600" Width="1000">

    <Window.DataContext>
        <vm:CzesciViewModel/>
    </Window.DataContext>
    
    <Grid>
        <DataGrid ItemsSource="{Binding Czesci}"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  AutoGenerateColumns="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Nazwa" Binding="{Binding Nazwa}" Width="*"/>
                <DataGridTextColumn Header="Nr katalogowy" Binding="{Binding NrKatalogowy}" Width="120"/>
                <DataGridTextColumn Header="Kategoria" Binding="{Binding Kategoria.Nazwa}" Width="120"/>
                <DataGridTextColumn Header="Cena" Binding="{Binding Cena, StringFormat={}{0:N2} zł}" Width="100"/>
                <DataGridTextColumn Header="Stan" Binding="{Binding StanMagazynowy}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

    </Grid>
</Window>
