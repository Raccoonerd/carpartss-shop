<Window x:Class="CarPartsStore.Views.KlienciView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:vm="clr-namespace:CarPartsStore.ViewModels"
        Title="Klienci" Height="600" Width="1000">

    <Window.DataContext>
        <vm:KlienciViewModel/>
    </Window.DataContext>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="3"
                   Text="Zarządzanie Klientami" FontSize="16" FontWeight="Bold"
                   Margin="0,0,0,10"/>

        <StackPanel Grid.Row="1" Grid.Column="0"
                    Orientation="Horizontal"
                    Margin="0,0,0,10">
            <TextBlock Text="Szukaj:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox Width="250"
                     Text="{Binding TekstWyszukiwania, UpdateSourceTrigger=PropertyChanged}"/>
        </StackPanel>

        <DataGrid Grid.Row="2" Grid.Column="0"
                  ItemsSource="{Binding Klienci}"
                  SelectedItem="{Binding WybranyKlient, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Nazwa Firmy" Binding="{Binding NazwaFirmy}" Width="*"/>
                <DataGridTextColumn Header="NIP" Binding="{Binding Nip}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="1" Grid.RowSpan="2" Grid.Column="2">
            <TextBlock Text="Formularz" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
            
            <TextBlock Text="Nazwa Firmy:"/>
            <TextBox Text="{Binding FormNazwa, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>
            
            <TextBlock Text="NIP:"/>
            <TextBox Text="{Binding FormNip, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

            <Button Content="Dodaj" Command="{Binding DodajCommand}"   Height="30" Margin="0,0,0,5"/>
            <Button Content="Zapisz zmiany" Command="{Binding ZapiszCommand}"  Height="30" Margin="0,0,0,5"/>
            <Button Content="Usuń" Command="{Binding UsunCommand}"    Height="30" Margin="0,0,0,5"/>
            <Button Content="Wyczyść" Command="{Binding WyczyscCommand}" Height="30"/>
        </StackPanel>

    </Grid>
</Window>
