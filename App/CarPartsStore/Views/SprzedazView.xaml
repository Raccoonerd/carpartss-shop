<UserControl x:Class="CarPartsStore.Views.SprzedazView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CarPartsStore.ViewModels">
    
    <UserControl.DataContext>
        <vm:SprzedazViewModel />
    </UserControl.DataContext>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="3"
                   Text="Sprzedaż"
                   FontSize="20" FontWeight="Bold"
                   Margin="0,0,0,10"/>

        <Grid Grid.Row="1" Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="Szukaj Części:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox Width="250"
                         Text="{Binding TekstWyszukiwania, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>

            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding DostepneCzesci}"
                      SelectedItem="{Binding WybranaCzesc, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Nazwa" Binding="{Binding Nazwa}" Width="*"/>
                    <DataGridTextColumn Header="Nr Katalogowy" Binding="{Binding NrKatalogowy}" Width="120"/>
                    <DataGridTextColumn Header="Cena" Binding="{Binding Cena, StringFormat={}{0:N2} zł}" Width="100"/>
                    <DataGridTextColumn Header="Stan" Binding="{Binding StanMagazynowy}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>

            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
                <TextBlock Text="Ilość:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox Width="60"
                         Text="{Binding IloscDoDodania, UpdateSourceTrigger=PropertyChanged}"
                         VerticalAlignment="Center"
                         Margin="0,0,10,0"/>
                <Button Content="Dodaj do koszyka"
                        Command="{Binding DodajDoKoszykaCommand}"
                        Width="100" Height="30"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <TextBlock Grid.Row="0" Text="Klient:" FontWeight="Bold" Margin="0,0,0,5"/>
            <ComboBox Grid.Row="1"
                      ItemsSource="{Binding Klienci}"
                      DisplayMemberPath="NazwaFirmy"
                      SelectedItem="{Binding WybranyKlient, Mode=TwoWay}"
                      Margin="0,0,0,15"/>
            
            <TextBlock Grid.Row="2" Text="Koszyk" FontWeight="Bold" VerticalAlignment="Top" Margin="0,0,0,5"/>
            <DataGrid Grid.Row="2"
                      ItemsSource="{Binding Koszyk}"
                      SelectedItem="{Binding WybranaPozycja, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      Margin="0,25,0,10">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Część" Binding="{Binding NazwaCzesci}" Width="*"/>
                    <DataGridTextColumn Header="Ilość" Binding="{Binding Ilosc}" Width="60"/>
                    <DataGridTextColumn Header="Cena" Binding="{Binding CenaJednostkowa, StringFormat={}{0:N2} zł}" Width="80"/>
                    <DataGridTextColumn Header="Suma" Binding="{Binding Suma, StringFormat={}{0:N2} zł}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>

            <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,10">
                <Button Content="Usuń pozycję"
                        Command="{Binding UsunPozycjeCommand}"
                        Width="120" Height="28" Margin="0,0,5,0"/>
                <Button Content="Wyczyść koszyk"
                        Command="{Binding WyczyscKoszykCommand}"
                        Width="120" Height="28"/>
            </StackPanel>

            <Border Grid.Row="4" BorderBrush="Gray" BorderThickness="1"
                    Padding="10" Margin="0,0,0,10">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Pozycji w koszyku: " FontWeight="Bold"/>
                        <TextBlock Text="{Binding LiczbaPozycji}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                        <TextBlock Text="Do zapłaty: " FontWeight="Black" FontSize="16"/>
                        <TextBlock Text="{Binding SumaCalkowita, StringFormat={}{0:N2} zł}"
                                   FontSize="16" FontWeight="Bold"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Button Grid.Row="5"
                    Content="Finalizuj Zamówienie"
                    Command="{Binding FinalizujCommand}"
                    Height="40" FontWeight="Bold"/>
        </Grid>

    </Grid>
</UserControl>
